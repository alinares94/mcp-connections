{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "mcp-route": {
        "ClusterId": "mcp-cluster",
        "Match": {
          "Path": "/api/mcp/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/mcp/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "mcp-cluster": {
        "Destinations": {
          "mcp-server": {
            "Address": "http://localhost:5000"
          }
        }
      }
    }
  }
}
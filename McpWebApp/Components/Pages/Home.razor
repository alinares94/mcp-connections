@page "/"
@inject McpService McpSvc

<PageTitle>MCP Control</PageTitle>

<!-- Top bar -->
<div class="topbar">
    <div class="topbar-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" />
        </svg>
    </div>
    <div class="topbar-text">
        <h1>MCP Control</h1>
        <p>Model Context Protocol &mdash; Gateway Test UI</p>
    </div>
    <div class="topbar-status">
        <span class="status-dot @(tools != null ? "active" : "")"></span>
        @if (tools != null)
        {
            <span>Connected</span>
        }
        else
        {
            <span>Idle</span>
        }
    </div>
</div>

<!-- Architecture diagram -->
<div class="arch-panel">
    <div class="arch-label">Request flow</div>
    <div class="arch-flow">
        <div class="arch-node node-client">Browser</div>

        <div class="arch-connector @(tools != null ? "active" : "") @(selectedGateway == "ocelot" ? "is-ocelot" : "")">
            <svg viewBox="0 0 28 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <line x1="2" y1="6" x2="22" y2="6" /><polyline points="18,2 22,6 18,10" />
            </svg>
        </div>

        <div class="arch-node node-webapp">McpWebApp<span class="port">:5002</span></div>

        <div class="arch-connector @(tools != null ? "active" : "") @(selectedGateway == "ocelot" ? "is-ocelot" : "")">
            <svg viewBox="0 0 28 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <line x1="2" y1="6" x2="22" y2="6" /><polyline points="18,2 22,6 18,10" />
            </svg>
        </div>

        <div class="arch-node node-gateway @(selectedGateway == "ocelot" ? "is-ocelot" : "")">
            @(selectedGateway == "yarp" ? "YARP Gateway" : "Ocelot Gateway")<span class="port">@(selectedGateway == "yarp" ? ":5001" : ":5003")</span>
        </div>

        <div class="arch-connector @(tools != null ? "active" : "") @(selectedGateway == "ocelot" ? "is-ocelot" : "")">
            <svg viewBox="0 0 28 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <line x1="2" y1="6" x2="22" y2="6" /><polyline points="18,2 22,6 18,10" />
            </svg>
        </div>

        <div class="arch-node node-server">McpServer<span class="port">:5000</span></div>
    </div>
</div>

<!-- Gateway selector -->
<div class="section">
    <div class="section-head">
        <span class="section-title">Gateway</span>
    </div>
    <div class="section-body">
        <div class="gw-options">
            <label class="gw-option @(selectedGateway == "yarp" ? "active-yarp" : "")" @onclick="@(() => SetGateway("yarp"))">
                <input type="radio" name="gw" value="yarp" checked="@(selectedGateway == "yarp")" />
                <span class="gw-radio"></span>
                <span class="gw-info">
                    <span class="gw-name">YARP</span>
                    <span class="gw-endpoint">localhost:5001/api/mcp/*</span>
                </span>
            </label>
            <label class="gw-option @(selectedGateway == "ocelot" ? "active-ocelot" : "")" @onclick="@(() => SetGateway("ocelot"))">
                <input type="radio" name="gw" value="ocelot" checked="@(selectedGateway == "ocelot")" />
                <span class="gw-radio"></span>
                <span class="gw-info">
                    <span class="gw-name">Ocelot</span>
                    <span class="gw-endpoint">localhost:5003/api/mcp/*</span>
                </span>
            </label>
        </div>
    </div>
</div>

<!-- Tools section -->
<div class="section">
    <div class="section-head">
        <span class="section-title">
            Tools
            @if (tools != null)
            {
                <span class="count">@tools.Count</span>
            }
        </span>
        <button class="btn btn-sm" @onclick="LoadTools" disabled="@loading">
            @if (loading)
            {
                <span class="spinner"></span>
                <span>Connecting...</span>
            }
            else
            {
                @(tools == null ? "Load Tools" : "Refresh")
            }
        </button>
    </div>

    @if (!loading && tools == null && errorMessage == null)
    {
        <div class="empty-state">
            <div class="icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                </svg>
            </div>
            <p>Click <strong>Load Tools</strong> to discover available MCP tools<br/>via the <strong>@selectedGateway.ToUpperInvariant()</strong> gateway.</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="conn-error">
            <div class="conn-error-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" />
                </svg>
            </div>
            <div class="conn-error-text">
                <strong>Connection failed</strong>
                <span class="detail">@errorMessage</span>
            </div>
        </div>
    }
    else if (tools?.Count == 0)
    {
        <div class="empty-state">
            <p>No tools found on the server.</p>
        </div>
    }
    else if (tools != null)
    {
        @foreach (var tool in tools)
        {
            <ToolCard Tool="tool" />
        }
    }
</div>

@code {
    private const string YarpUrl = "http://localhost:5001/api/mcp/analysis";
    private const string OcelotUrl = "http://localhost:5003/api/mcp/analysis";

    private string selectedGateway = "yarp";
    private List<ToolInfo>? tools;
    private bool loading;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        McpSvc.GatewayUrl = YarpUrl;
    }

    private void SetGateway(string gateway)
    {
        selectedGateway = gateway;
        McpSvc.GatewayUrl = gateway == "yarp" ? YarpUrl : OcelotUrl;
        tools = null;
        errorMessage = null;
    }

    private async Task LoadTools()
    {
        loading = true;
        errorMessage = null;
        tools = null;

        try
        {
            tools = await McpSvc.ListToolsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}
